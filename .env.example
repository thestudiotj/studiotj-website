# StudioTJ — Environment Variables
# Copy this to .env.local and fill in your values

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SITE_URL=https://studiotj.com

# Prodigi print-on-demand
PRODIGI_API_KEY=...
PRODIGI_SANDBOX=false
# Signed-URL token registered in Prodigi dashboard as the callback URL query param
PRODIGI_WEBHOOK_SECRET=

# Admin
STUDIOTJ_ADMIN_EMAIL=thestudiotj@gmail.com

# Email — choose ONE provider:

# Option A: Resend (recommended — resend.com, free up to 3k emails/month)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...

# Option B: Mailchimp
MAILCHIMP_API_KEY=...
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=...

# Scout app
SCOUT_PASSWORD=your-scout-password-here

# Scout — self-hosted Overpass (overpass.studiotj.com via Cloudflare Access)
# If set, Scout uses the self-hosted instance first and falls back to public mirrors.
# Leave unset in local dev to always use public mirrors.
OVERPASS_ENDPOINT=https://overpass.studiotj.com/api/interpreter
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Vondsten — Amazon affiliate partner tag (set in Vercel after qualifying sales)
NEXT_PUBLIC_AMAZON_PARTNER_TAG=your-partner-tag-here

# StudioTJ — Environment Variables
# Copy this to .env.local and fill in your values

# Anthropic (for the photo sorter — not needed for the website)
ANTHROPIC_API_KEY=sk-ant-...

# Shopify Storefront API (connect your existing store)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your-public-storefront-access-token

# Email — choose ONE provider:

# Option A: Resend (recommended — resend.com, free up to 3k emails/month)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...

# Option B: Mailchimp
MAILCHIMP_API_KEY=...
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=...

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

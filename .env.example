# StudioTJ — Environment Variables
# Copy this to .env.local and fill in your values

# Email — choose ONE provider:

# Option A: Resend (recommended — resend.com, free up to 3k emails/month)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...

# Option B: Mailchimp
MAILCHIMP_API_KEY=...
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=...

# Scout app
SCOUT_PASSWORD=your-scout-password-here

# Vondsten — Amazon affiliate partner tag (set in Vercel after qualifying sales)
NEXT_PUBLIC_AMAZON_PARTNER_TAG=your-partner-tag-here
